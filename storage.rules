rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Chat file uploads — only session participants
    // Path: sessions/{sessionId}/chat/{filename}
    match /sessions/{sessionId}/chat/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // max 10 MB
        && request.resource.contentType.matches('image/.*|application/pdf|application/msword|application/vnd\\.openxmlformats.*|text/plain');
    }
  }
}
